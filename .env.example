# Public build-time variable used by the contact form.
PUBLIC_WEB3FORMS_ACCESS_KEY=access-key

# Reserved for possible future Firebase analytics reactivation.
# Not used by the site right now.
PUBLIC_FIREBASE_API_KEY=api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=domain
PUBLIC_FIREBASE_PROJECT_ID=project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=storage-bucket
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=messaging-sender-id
PUBLIC_FIREBASE_APP_ID=app-id
PUBLIC_FIREBASE_MEASUREMENT_ID=measurement-id

# Firebase project used by the deploy script.
FIREBASE_PROJECT_ID=project-id

# Optional preview settings for local preview deploys. If ommitted, uses 'live-preview'
FIREBASE_PREVIEW_CHANNEL=
FIREBASE_PREVIEW_EXPIRES=7d

# Optional for CI/GitHub Actions.
# You can either:
# - store the full service account JSON as a single GitHub secret value, or
# - point to a local service account JSON file path for local preview deploys.
FIREBASE_SERVICE_ACCOUNT_JSON=
