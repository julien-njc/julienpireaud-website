# Public build-time variable used by the contact form.
PUBLIC_WEB3FORMS_ACCESS_KEY=

# Firebase project used by the deploy script.
FIREBASE_PROJECT_ID=

# Optional Hosting site override. If omitted, deploy uses FIREBASE_PROJECT_ID.
FIREBASE_HOSTING_SITE=

# Optional for CI/GitHub Actions.
# Store the full service account JSON as a single GitHub secret value.
# The deploy script writes it to a temporary file and sets GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_JSON=
